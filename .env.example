# ─────────────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
# Canonical base URL of the deployed app (replaces REPLIT_DOMAINS).
# In prod on Vercel: https://your-app.vercel.app
APP_BASE_URL=http://localhost:5000
# Used to sign express-session cookies AND as the encryption key
# in server/encryption.ts. Must be a long random string.
SESSION_SECRET=replace-with-long-random-string

# ─────────────────────────────────────────────────────────────────────
# Database (Neon PostgreSQL)
# ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require

# ─────────────────────────────────────────────────────────────────────
# Email (Resend) — direct API, no Replit connector
# ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=OrderFlowAI <noreply@yourdomain.com>

# ─────────────────────────────────────────────────────────────────────
# Shopify
# ─────────────────────────────────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
# SHOPIFY_STORE_URL=                 # alias; either works
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Fastrr (checkout webhooks)
# ─────────────────────────────────────────────────────────────────────
FASTRR_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Shiprocket
# ─────────────────────────────────────────────────────────────────────
SHIPROCKET_API_EMAIL=
SHIPROCKET_API_PASSWORD=
SHIPROCKET_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Delhivery
# ─────────────────────────────────────────────────────────────────────
DELHIVERY_API_TOKEN=
DELHIVERY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# TeleCRM / IVR Solutions (Click2Call + inbound webhooks)
# ─────────────────────────────────────────────────────────────────────
IVR_API_TOKEN=
IVR_DID_NUMBER=
IVR_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Scalysis AI (calling agent) — posts call transcripts to n8n for analysis
# ─────────────────────────────────────────────────────────────────────
N8N_ANALYZE_CALL_URL=https://n8n.yourhost.tld/webhook/analyze-call
