# Dependencies & build
node_modules/
dist/
build/
.cache/

# Env / secrets — never commit. .env.example is tracked as a template.
.env
.env.local
.env.*.local

# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp

# Local-only Claude state + worktrees
.claude/
.agents/
.local/
.config/

# Uploads (KYC docs, payslip PDFs — local-only, may contain PII).
# Keep the dir scaffolding so the app boots; ignore contents.
# Payroll PDFs in uploads/payslips/ in particular MUST NEVER be pushed.
uploads/**
!uploads/
!uploads/**/.gitkeep

# Logs
logs/
*.log

# Large local-only seed data (23 MB — host elsewhere)
pincodes.csv

# Reference PDFs dropped into the repo locally
*.pdf

# Archives sometimes left over from local builds
*.tar.gz

# tsx/Vite intermediate
vite.config.ts.*

# Bundled API serverless function — regenerated each deploy by
# scripts/build-api.mjs. Source of truth lives at server/api-handler.ts.
api/index.js
api/index.js.map
.vercel
.env*.local
