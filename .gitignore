# Dependencies & build
node_modules/
dist/
build/
.cache/

# Env / secrets — never commit. .env.example is tracked as a template.
.env
.env.local
.env.*.local

# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp

# Local-only Claude state + worktrees
.claude/
.agents/
.local/
.config/

# Uploads (KYC docs, payslip PDFs — local-only, may contain PII).
# Keep the dir scaffolding so the app boots; ignore contents.
# Payroll PDFs in uploads/payslips/ in particular MUST NEVER be pushed.
uploads/**
!uploads/
!uploads/**/.gitkeep

# Logs
logs/
*.log

# Large local-only seed data (23 MB — host elsewhere)
pincodes.csv

# Reference PDFs dropped into the repo locally
*.pdf

# Archives sometimes left over from local builds
*.tar.gz

# tsx/Vite intermediate
vite.config.ts.*

# Bundled API serverless function — regenerated by scripts/build-api.mjs.
# Source of truth: server/api-handler.ts → bundled into api/index.js.
#
# We DO commit api/index.js because Vercel's functions-pattern validator
# runs BEFORE installCommand/buildCommand, so the file must exist at
# git-clone time or auto-deploys fail with "pattern doesn't match any
# Serverless Functions". The .githook/pre-push hook (see scripts/setup-hooks.mjs
# or run `npm run setup:hooks`) re-runs the bundler on every push so a
# stale committed bundle never ships.
#
# Sourcemap stays ignored — we don't need it in production and it
# bloats the repo by ~500KB per push.
api/index.js.map
.vercel
.env*.local
